# ── VH Conference Toolkit — Ops Tracker ─────────────────────────────────────
# Copy this file to .env and fill in values as needed.
# The tool works without any of these — they're all optional.

# Port to serve the tool on (default: 8080)
# PORT=8080

# Optional: Anthropic API key for AI-powered setup help.
# If set, the setup script will ask Claude to explain any errors in plain English.
# Get a key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
